# ============================================================
# World Multi-Agent System for Healthcare — Environment Config
# ============================================================

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Epic FHIR Base URL
EPIC_FHIR_BASE_URL=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4

# Epic OAuth2 SMART on FHIR
EPIC_CLIENT_ID=your_epic_client_id
EPIC_CLIENT_SECRET=your_epic_client_secret
EPIC_REDIRECT_URI=https://localhost/callback
EPIC_TOKEN_URL=https://fhir.epic.com/interconnect-fhir-oauth/oauth2/token
EPIC_AUTHORIZE_URL=https://fhir.epic.com/interconnect-fhir-oauth/oauth2/authorize

# Epic Backend Services (JWT / RS384)
# Generate RSA keypair: openssl genrsa -out epic_private_key.pem 2048
# Register the PUBLIC key in Epic App Orchard under your app
EPIC_PRIVATE_KEY_PATH=./epic_private_key.pem

# Redis Memory (optional — in-memory used by default)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# System
LOG_LEVEL=INFO
ENVIRONMENT=development
